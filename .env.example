# Copy to .env.local and fill in. NEVER commit real values.
# Find these in: Supabase dashboard -> Project Settings -> API

# Public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Server-only secrets (NEVER prefix with NEXT_PUBLIC, never import in client code)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Transactional email for the login verification code (Phase 3+).
# Using Resend: https://resend.com -> API Keys
RESEND_API_KEY=""
LOGIN_CODE_FROM_EMAIL="Little Talkers <no-reply@yourdomain.com>"
